<link rel="stylesheet" href="/css/detail_ruangan.css" />

<%
  const mainImgUrl = mainPhoto ? `/uploads/rooms/${mainPhoto.filename}` : 'https://placehold.co/800x600?text=No+Image';
  const activeSchedules = schedules || [];
  const scheduleText = activeSchedules.length
    ? activeSchedules.map((item) => `${item.hari} ${item.jam_mulai}-${item.jam_selesai}`).join(', ')
    : '07:00-21:00';
%>

<div class="room-detail-page">
  <section class="room-hero">
    <div class="room-gallery" id="media">
      <img id="mainImg" src="<%= mainImgUrl %>" alt="<%= room.name %>">

      <% if (photos && photos.length > 0) { %>
        <div class="thumbs" id="thumbs" aria-label="Galeri foto ruangan">
          <% photos.forEach((photo, index) => { %>
            <button
              type="button"
              class="thumb <%= (mainPhoto && photo.id === mainPhoto.id) ? 'active' : '' %>"
              data-src="/uploads/rooms/<%= photo.filename %>"
              aria-label="Lihat foto ruangan <%= index + 1 %>">
              <img src="/uploads/rooms/<%= photo.filename %>" alt="Foto ruangan <%= index + 1 %>">
            </button>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div class="room-summary">
      <div class="room-kicker">Detail Ruangan</div>
      <h1><%= room.name %></h1>
      <p><%= room.deskripsi || 'Ruangan ini tersedia untuk kegiatan akademik dan dapat diajukan melalui sistem E-Ruang.' %></p>

      <div class="summary-grid">
        <div>
          <span>Gedung</span>
          <strong><%= room.gedung || '-' %></strong>
        </div>
        <div>
          <span>Nomor Ruang</span>
          <strong><%= room.nomor_ruang || room.code || '-' %></strong>
        </div>
        <div>
          <span>Kapasitas</span>
          <strong><%= room.capacity || 0 %> orang</strong>
        </div>
        <div>
          <span>Jam Operasional</span>
          <strong><%= activeSchedules[0] ? `${activeSchedules[0].jam_mulai}-${activeSchedules[0].jam_selesai}` : '07:00-21:00' %></strong>
        </div>
      </div>

      <div class="facility-list" aria-label="Fasilitas ruangan">
        <% if (facilities && facilities.length > 0) { %>
          <% facilities.forEach((item) => { %>
            <span><%= item.nama || item.name %></span>
          <% }); %>
        <% } else { %>
          <span>Fasilitas belum tercatat</span>
        <% } %>
      </div>
    </div>
  </section>

  <section
    class="availability-shell"
    id="kalender-ketersediaan"
    data-room-id="<%= room.id %>"
    data-is-logged-in="<%= isLoggedIn ? 'true' : 'false' %>">
    <div class="calendar-main">
      <div class="calendar-toolbar">
        <div>
          <span class="section-label">Kalender Ketersediaan</span>
          <h2>Jadwal <%= room.name %></h2>
          <p>Pilih slot kosong pada kalender untuk mengisi formulir peminjaman secara otomatis.</p>
        </div>

        <div class="calendar-actions">
          <label class="room-select-label" for="roomSelector">Pilih Ruangan</label>
          <select id="roomSelector" class="room-select" aria-label="Pilih ruangan">
            <% (rooms || []).forEach((item) => { %>
              <option value="<%= item.id %>" <%= Number(item.id) === Number(room.id) ? 'selected' : '' %>>
                <%= item.name %> - <%= item.gedung || 'Gedung' %>
              </option>
            <% }); %>
          </select>

          <div class="view-toggle" role="group" aria-label="Navigasi tampilan kalender">
            <button type="button" class="view-btn" data-view="timeGridDay">Hari</button>
            <button type="button" class="view-btn active" data-view="timeGridWeek">Minggu</button>
            <button type="button" class="view-btn" data-view="dayGridMonth">Bulan</button>
          </div>
        </div>
      </div>

      <div class="calendar-status loading" id="calendarLoading">Memuat ketersediaan ruangan...</div>
      <div class="calendar-status error" id="calendarError" hidden>Gagal memuat kalender. Silakan coba beberapa saat lagi.</div>
      <div class="calendar-status empty" id="calendarEmpty" hidden>Tidak ada peminjaman pada rentang ini. Slot dalam jam operasional dapat diajukan.</div>

      <div class="calendar-card">
        <div id="availabilityCalendar"></div>
      </div>
    </div>

    <aside class="booking-side">
      <div class="legend-card">
        <h3>Legend Status</h3>
        <div class="legend-item">
          <span class="legend-dot empty"></span>
          <div>
            <strong>Kosong</strong>
            <p>Slot dalam jam operasional dan dapat diklik.</p>
          </div>
        </div>
        <div class="legend-item">
          <span class="legend-dot approved"></span>
          <div>
            <strong>Terisi</strong>
            <p>Peminjaman sudah disetujui admin.</p>
          </div>
        </div>
        <div class="legend-item">
          <span class="legend-dot pending"></span>
          <div>
            <strong>Menunggu Persetujuan</strong>
            <p>Pengajuan sedang diproses admin.</p>
          </div>
        </div>
      </div>

      <div class="booking-panel" id="booking">
        <div class="panel-heading">
          <span>Form Booking</span>
          <strong><%= room.name %></strong>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="form-alert error"><%= error %></div>
        <% } %>

        <div id="queryAlert" class="form-alert" hidden></div>
        <div id="loginNotice" class="form-alert info" hidden>
          Silakan login terlebih dahulu untuk mengajukan peminjaman ruangan.
          <a href="/login?redirect=/room/<%= room.id %>">Login</a>
        </div>

        <form id="bookingForm" action="/booking/create" method="POST">
          <input type="hidden" id="room_id" name="room_id" value="<%= room.id %>">

          <div class="row">
            <label for="date">Tanggal</label>
            <input id="date" name="date" type="date" required />
          </div>

          <div class="time-row">
            <div class="row">
              <label for="start">Jam Mulai</label>
              <input id="start" name="start" type="time" required />
            </div>
            <div class="row">
              <label for="end">Jam Selesai</label>
              <input id="end" name="end" type="time" required />
            </div>
          </div>

          <div class="row">
            <label for="name">Penanggung Jawab</label>
            <input
              id="name"
              name="name"
              type="text"
              value="<%= currentUser && currentUser.name ? currentUser.name : '' %>"
              placeholder="Nama / NIM / organisasi"
              required />
          </div>

          <div class="row">
            <label for="note">Catatan</label>
            <textarea id="note" name="note" rows="3" placeholder="Keperluan peminjaman"></textarea>
          </div>

          <div id="msg" aria-live="polite"></div>
          <button type="submit" class="submit-booking">Kirim Permintaan</button>
          <p class="small-info">Pengajuan akan berstatus Menunggu Persetujuan sampai diverifikasi admin.</p>
        </form>
      </div>

      <div class="schedule-note">
        <strong>Jam operasional lengkap</strong>
        <p><%= scheduleText %></p>
      </div>
    </aside>
  </section>
</div>

<script>
  window.roomCalendarConfig = {
    roomId: <%- JSON.stringify(room.id) %>,
    isLoggedIn: <%- JSON.stringify(Boolean(isLoggedIn)) %>,
    schedules: <%- JSON.stringify(activeSchedules) %>
  };
</script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.15/locales-all.global.min.js"></script>
<script src="/js/detail_ruangan.js"></script>
