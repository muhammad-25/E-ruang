<link rel="stylesheet" href="/css/admin-ulasan.css">

<div class="reviews-admin-container">
  <div class="reviews-admin-card">
    <div class="reviews-admin-header">
      <div>
        <h2>Moderasi Ulasan</h2>
        <p>Lihat, sembunyikan, tampilkan, atau hapus ulasan ruangan yang masuk.</p>
      </div>
      <span><%= reviews.length %> ulasan</span>
    </div>

    <div class="table-responsive">
      <table class="reviews-table">
        <thead>
          <tr>
            <th>Pengguna</th>
            <th>Ruangan</th>
            <th>Rating</th>
            <th>Komentar</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (reviews.length > 0) { %>
            <% reviews.forEach((review) => { %>
              <tr>
                <td>
                  <strong><%= review.user_name %></strong>
                  <small>NIM: <%= review.NIM || '-' %></small>
                </td>
                <td>
                  <strong><%= review.room_name %></strong>
                  <small><%= review.gedung || '-' %></small>
                  <small><%= review.bookingLabel %></small>
                </td>
                <td>
                  <span class="rating-stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></span>
                  <small><%= review.createdLabel %></small>
                </td>
                <td class="comment-cell"><%= review.comment %></td>
                <td>
                  <span class="review-badge <%= Number(review.is_visible) === 1 ? 'visible' : 'hidden' %>">
                    <%= review.statusLabel %>
                  </span>
                </td>
                <td>
                  <div class="review-actions">
                    <form action="/admin/ulasan/<%= review.id %>" method="POST">
                      <input type="hidden" name="action" value="<%= Number(review.is_visible) === 1 ? 'hide' : 'show' %>">
                      <button type="submit" class="btn-review-action btn-blue">
                        <%= Number(review.is_visible) === 1 ? 'Sembunyikan' : 'Tampilkan' %>
                      </button>
                    </form>
                    <form action="/admin/ulasan/<%= review.id %>" method="POST" onsubmit="return confirm('Hapus ulasan ini?')">
                      <input type="hidden" name="action" value="delete">
                      <button type="submit" class="btn-review-action btn-red">Hapus</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty-review-row">Belum ada ulasan yang masuk.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
