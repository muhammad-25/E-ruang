<link rel="stylesheet" href="/css/admin-chat.css">

<div class="admin-chat-container">
    <div class="chat-dashboard-header">
        <h2>Pesan Masuk (Chat Admin)</h2>
        <p>Kelola dan tanggapi pertanyaan dari pengguna secara langsung.</p>
    </div>

    <div class="chat-dashboard-card">
        <div class="chat-sidebar">
            <div class="chat-search-wrap">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="userSearch" onkeyup="filterUsers()" placeholder="Cari nama user..." />
            </div>

            <div class="user-list" id="userList"></div>
        </div>

        <div class="chat-area" id="chatArea">
            <div class="chat-empty-state" id="chatEmptyState">
                <div class="empty-icon-wrapper">
                    <i class="fa-solid fa-comments"></i>
                </div>
                <h3>Mulai Percakapan</h3>
                <p>Pilih salah satu user di panel kiri untuk melihat riwayat pesan dan mulai mengirim balasan.</p>
            </div>

            <div class="chat-active-state" id="chatActiveState" style="display: none;">
                <div class="active-chat-header">
                    <div class="active-user-info">
                        <div class="active-user-avatar" id="activeUserAvatar">U</div>
                        <div class="active-user-details">
                            <h4 id="activeUserName">Nama User</h4>
                            <span class="active-user-status"><span class="dot"></span> Online</span>
                        </div>
                    </div>
                </div>

                <div class="admin-chat-messages" id="adminChatMessages"></div>

                <div class="admin-chat-input-bar">
                    <form id="adminChatForm" onsubmit="handleAdminSubmit(event)" class="admin-chat-form">
                        <input
                            type="text"
                            id="adminChatInput"
                            class="admin-chat-input-field"
                            placeholder="Tulis balasan..."
                            autocomplete="off"
                            required
                        />
                        <button type="submit" class="admin-chat-send-btn">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    let adminSocket = null;
    let conversationsState = [];
    let activeThreadId = null;
    let activeConversation = null;
    const messagesByThread = new Map();

    document.addEventListener("DOMContentLoaded", () => {
        loadConversations();
        connectAdminSocket();
    });

    async function loadConversations() {
        try {
            const response = await fetch('/api/chat/conversations');
            if (!response.ok) return;

            const data = await response.json();
            if (!data.success) return;

            conversationsState = data.conversations || [];
            loadUserList();
        } catch (err) {
            console.error('Gagal memuat percakapan:', err);
        }
    }

    function connectAdminSocket() {
        if (!window.io) return;

        adminSocket = io();

        adminSocket.on('chat:conversations', (payload) => {
            conversationsState = payload.conversations || [];
            loadUserList();
        });

        adminSocket.on('chat:conversation_updated', (payload) => {
            if (!payload || !payload.conversation) return;
            upsertConversation(payload.conversation);
            loadUserList();
        });

        adminSocket.on('chat:message', (payload) => {
            if (!payload || !payload.message) return;
            if (Number(payload.message.thread_id) !== Number(activeThreadId)) return;

            upsertConversation(payload.conversation);
            upsertThreadMessage(activeThreadId, payload.message);
            renderAdminMessages();
            markActiveConversationRead();
            loadUserList();
        });

        adminSocket.on('chat:conversation_read', (payload) => {
            if (!payload || Number(payload.thread_id) !== Number(activeThreadId)) return;
            loadConversations();
        });
    }

    function loadUserList() {
        const userListContainer = document.getElementById('userList');
        if (!userListContainer) return;

        const searchValue = (document.getElementById('userSearch')?.value || '').toLowerCase();
        userListContainer.innerHTML = '';

        const filtered = conversationsState
            .filter(item => (item.user_name || '').toLowerCase().includes(searchValue))
            .sort((a, b) => new Date(b.last_message_at || b.updated_at) - new Date(a.last_message_at || a.updated_at));

        if (filtered.length === 0) {
            userListContainer.innerHTML = '<div class="chat-list-empty">Belum ada percakapan.</div>';
            return;
        }

        filtered.forEach(conversation => {
            const itemDiv = document.createElement('div');
            itemDiv.className = `user-item ${Number(activeThreadId) === Number(conversation.thread_id) ? 'active' : ''}`;
            itemDiv.onclick = () => selectConversation(conversation.thread_id);

            const initial = (conversation.user_name || 'U').charAt(0).toUpperCase();
            const lastText = conversation.last_message_text || 'Belum ada pesan';
            const truncatedMsg = lastText.length > 35 ? lastText.substring(0, 35) + '...' : lastText;
            const unreadBadge = conversation.unread_count > 0
                ? `<span class="user-unread-badge">${conversation.unread_count > 99 ? '99+' : conversation.unread_count}</span>`
                : '';

            itemDiv.innerHTML = `
                <div class="user-avatar-wrapper">
                    <div class="user-item-avatar">${initial}</div>
                    <span class="user-status-dot"></span>
                </div>
                <div class="user-item-details">
                    <div class="user-item-header">
                        <span class="user-item-name">${escapeHTML(conversation.user_name || 'User')}</span>
                        <span class="user-item-time">${conversation.last_message_at ? formatTime(conversation.last_message_at) : ''}</span>
                    </div>
                    <p class="user-item-msg">${escapeHTML(truncatedMsg)} ${unreadBadge}</p>
                </div>
            `;

            userListContainer.appendChild(itemDiv);
        });
    }

    function filterUsers() {
        loadUserList();
    }

    async function selectConversation(threadId) {
        activeThreadId = threadId;
        activeConversation = conversationsState.find(item => Number(item.thread_id) === Number(threadId)) || null;

        document.getElementById('chatEmptyState').style.display = 'none';
        document.getElementById('chatActiveState').style.display = 'flex';

        updateActiveHeader();
        loadUserList();

        if (adminSocket && adminSocket.connected) {
            adminSocket.emit('chat:join', { thread_id: threadId }, (response) => {
                if (response && response.success) {
                    activeConversation = response.conversation || activeConversation;
                    messagesByThread.set(Number(threadId), response.messages || []);
                    renderAdminMessages();
                    markActiveConversationRead();
                    focusInput();
                }
            });
        } else {
            await loadMessagesByHttp(threadId);
            markActiveConversationRead();
            focusInput();
        }
    }

    async function loadMessagesByHttp(threadId) {
        try {
            const response = await fetch(`/api/chat/conversations/${threadId}/messages`);
            if (!response.ok) return;

            const data = await response.json();
            if (!data.success) return;

            activeConversation = data.conversation || activeConversation;
            messagesByThread.set(Number(threadId), data.messages || []);
            renderAdminMessages();
        } catch (err) {
            console.error('Gagal memuat pesan:', err);
        }
    }

    function updateActiveHeader() {
        if (!activeConversation) return;

        const initial = (activeConversation.user_name || 'U').charAt(0).toUpperCase();
        document.getElementById('activeUserName').innerText = activeConversation.user_name || 'User';
        document.getElementById('activeUserAvatar').innerText = initial;
    }

    function renderAdminMessages() {
        const messagesContainer = document.getElementById('adminChatMessages');
        if (!messagesContainer || !activeThreadId) return;

        const activeMessages = messagesByThread.get(Number(activeThreadId)) || [];
        messagesContainer.innerHTML = '';

        activeMessages.forEach(msg => {
            const msgDiv = document.createElement('div');
            msgDiv.className = `admin-msg ${msg.sender_type === 'admin' ? 'sent' : 'received'}`;
            msgDiv.innerHTML = `
                <div class="admin-msg-bubble">${escapeHTML(msg.message_text)}</div>
                <div class="admin-msg-time">${formatTime(msg.created_at)}</div>
            `;
            messagesContainer.appendChild(msgDiv);
        });

        scrollToBottom();
    }

    async function handleAdminSubmit(e) {
        e.preventDefault();
        const input = document.getElementById('adminChatInput');
        const text = input.value.trim();
        if (!text || !activeThreadId) return;

        input.value = '';

        if (adminSocket && adminSocket.connected) {
            adminSocket.emit('chat:message', { thread_id: activeThreadId, message_text: text }, (response) => {
                if (response && response.success && response.message) {
                    upsertThreadMessage(activeThreadId, response.message);
                    renderAdminMessages();
                }
            });
            return;
        }

        try {
            const response = await fetch('/api/chat/messages', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ thread_id: activeThreadId, message_text: text })
            });
            const data = await response.json();
            if (data.success && data.message) {
                upsertThreadMessage(activeThreadId, data.message);
                renderAdminMessages();
                loadConversations();
            }
        } catch (err) {
            console.error('Gagal mengirim pesan:', err);
        }
    }

    function upsertConversation(conversation) {
        if (!conversation) return;

        const index = conversationsState.findIndex(item => Number(item.thread_id) === Number(conversation.thread_id));
        if (index >= 0) {
            conversationsState[index] = conversation;
        } else {
            conversationsState.push(conversation);
        }

        if (Number(activeThreadId) === Number(conversation.thread_id)) {
            activeConversation = conversation;
            updateActiveHeader();
        }
    }

    function upsertThreadMessage(threadId, message) {
        const key = Number(threadId);
        const list = messagesByThread.get(key) || [];
        const index = list.findIndex(item => Number(item.id) === Number(message.id));

        if (index >= 0) {
            list[index] = message;
        } else {
            list.push(message);
        }

        list.sort((a, b) => Number(a.id) - Number(b.id));
        messagesByThread.set(key, list);
    }

    function markActiveConversationRead() {
        if (!activeThreadId) return;

        const activeIndex = conversationsState.findIndex(item => Number(item.thread_id) === Number(activeThreadId));
        if (activeIndex >= 0) {
            conversationsState[activeIndex].unread_count = 0;
        }

        if (adminSocket && adminSocket.connected) {
            adminSocket.emit('chat:read', { thread_id: activeThreadId });
        } else {
            fetch(`/api/chat/conversations/${activeThreadId}/read`, { method: 'POST' }).catch(() => {});
        }
    }

    function focusInput() {
        setTimeout(() => {
            document.getElementById('adminChatInput').focus();
            scrollToBottom();
        }, 100);
    }

    function scrollToBottom() {
        const container = document.getElementById('adminChatMessages');
        if (container) container.scrollTop = container.scrollHeight;
    }

    function formatTime(isoString) {
        const d = new Date(isoString);
        return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }).replace(':', '.');
    }

    function escapeHTML(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }
</script>
