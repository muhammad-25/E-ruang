<nav>
  <div class="left">
    <img src="/assets/logo-unj.png" alt="Logo" />
    <span>E-Ruang UNJ</span>
  </div>

  <div class="hamburger" id="hamburger" aria-label="Menu">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="nav-right" id="nav-right">
    <div class="menu">
      <a href="/">Beranda</a>
      <a href="listRuangan">Ruangan</a>
      <a href="/history">Riwayat</a>
    </div> 

    <div class="buttons">
      <% if (isLoggedIn) { %>
        <a href="/profile"><button class="btn login">Profil</button></a>
      <% } else { %>
        <a href="/register"><button class="btn">Register</button></a>
        <a href="/login"><button class="btn login">Log In</button></a>
      <% } %>
    </div>
  </div>

  <script>
    const currentPath = window.location.pathname;
    const menuLinks = document.querySelectorAll('.menu a');

    menuLinks.forEach(link => {
      const linkPath = link.getAttribute('href');
      if (linkPath === currentPath || (linkPath.startsWith('/') && linkPath === currentPath) || (!linkPath.startsWith('/') && '/' + linkPath === currentPath)) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    const hamburger = document.getElementById('hamburger');
    const navRight = document.getElementById('nav-right');

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navRight.classList.toggle('active');
    });
  </script>
</nav>