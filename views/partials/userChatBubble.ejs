<!-- User Chat Bubble & Panel -->
<div class="user-chat-container" id="userChatContainer">
    <button class="chat-bubble-btn" id="chatBubbleBtn" onclick="toggleChatPanel()">
        <i class="fa-solid fa-comments"></i>
        <span class="chat-bubble-badge" id="chatBadge" style="display: none;">0</span>
    </button>

    <div class="chat-panel" id="chatPanel">
        <div class="chat-header">
            <div class="chat-admin-info">
                <div class="chat-avatar-wrapper">
                    <div class="chat-admin-avatar">A</div>
                    <span class="status-dot"></span>
                </div>
                <div class="chat-admin-meta">
                    <h4 class="chat-admin-title">Admin E-Ruang</h4>
                    <p class="chat-admin-subtitle">Online - Siap membantu</p>
                </div>
            </div>
            <button class="chat-close-btn" onclick="toggleChatPanel()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="chat-messages" id="chatMessages"></div>

        <div class="chat-input-area">
            <form id="chatForm" onsubmit="handleUserSubmit(event)" class="chat-input-form">
                <input
                    type="text"
                    id="chatInput"
                    class="chat-input-field"
                    placeholder="Tulis pesan..."
                    autocomplete="off"
                    required
                />
                <button type="submit" class="chat-send-btn">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const chatUser = {
        id: <%- JSON.stringify(user.userId || null) %>,
        name: <%- JSON.stringify(user.userName || 'User') %>,
        email: <%- JSON.stringify(user.userEmail || '') %>
    };

    let chatSocket = null;
    let activeConversation = null;
    let chatMessagesState = [];
    let isChatOpen = false;
    let unreadCount = 0;

    document.addEventListener("DOMContentLoaded", () => {
        loadInitialChat();
        connectUserChatSocket();
    });

    async function loadInitialChat() {
        try {
            const response = await fetch('/api/chat/me');
            if (!response.ok) return;

            const data = await response.json();
            if (!data.success) return;

            activeConversation = data.conversation;
            chatMessagesState = data.messages || [];
            unreadCount = activeConversation.unread_count || 0;
            updateBadge();
            renderChatMessages();
        } catch (err) {
            console.error('Gagal memuat chat:', err);
        }
    }

    function connectUserChatSocket() {
        if (!window.io) return;

        chatSocket = io();

        chatSocket.on('chat:ready', (payload) => {
            activeConversation = payload.conversation;
            chatMessagesState = payload.messages || [];
            unreadCount = activeConversation.unread_count || 0;
            updateBadge();
            renderChatMessages();
        });

        chatSocket.on('chat:message', (payload) => {
            if (!payload || !payload.message) return;
            if (activeConversation && payload.message.thread_id !== activeConversation.thread_id) return;

            upsertMessage(payload.message);
            if (payload.conversation) activeConversation = payload.conversation;
            renderChatMessages();

            if (payload.message.sender_type === 'admin') {
                if (isChatOpen) {
                    markConversationRead();
                } else {
                    unreadCount += 1;
                    updateBadge();
                }
            }
        });

        chatSocket.on('chat:conversation_updated', (payload) => {
            if (!payload || !payload.message) return;
            if (activeConversation && payload.message.thread_id !== activeConversation.thread_id) return;
            upsertMessage(payload.message);
            renderChatMessages();
        });
    }

    function toggleChatPanel() {
        const panel = document.getElementById('chatPanel');
        isChatOpen = !isChatOpen;

        if (isChatOpen) {
            panel.classList.add('open');
            clearBadge();
            markConversationRead();
            setTimeout(() => {
                document.getElementById('chatInput').focus();
                scrollToBottom();
            }, 300);
        } else {
            panel.classList.remove('open');
        }
    }

    function renderChatMessages() {
        const messagesContainer = document.getElementById('chatMessages');
        if (!messagesContainer) return;

        messagesContainer.innerHTML = '';

        if (chatMessagesState.length === 0) {
            const emptyDiv = document.createElement('div');
            emptyDiv.className = 'chat-msg received';
            emptyDiv.innerHTML = `
                <div class="chat-msg-bubble">
                    Halo ${escapeHTML(chatUser.name)}! Ada yang bisa kami bantu mengenai peminjaman ruangan di E-Ruang?
                </div>
                <div class="chat-msg-time">${formatTime(new Date().toISOString())}</div>
            `;
            messagesContainer.appendChild(emptyDiv);
            return;
        }

        chatMessagesState.forEach(msg => {
            const msgDiv = document.createElement('div');
            msgDiv.className = `chat-msg ${msg.sender_type === 'user' ? 'sent' : 'received'}`;
            msgDiv.innerHTML = `
                <div class="chat-msg-bubble">${escapeHTML(msg.message_text)}</div>
                <div class="chat-msg-time">${formatTime(msg.created_at)}</div>
            `;
            messagesContainer.appendChild(msgDiv);
        });

        if (isChatOpen) scrollToBottom();
    }

    async function handleUserSubmit(e) {
        e.preventDefault();
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text) return;

        input.value = '';

        if (chatSocket && chatSocket.connected) {
            chatSocket.emit('chat:message', { message_text: text }, (response) => {
                if (response && response.success && response.message) {
                    upsertMessage(response.message);
                    renderChatMessages();
                }
            });
            return;
        }

        try {
            const response = await fetch('/api/chat/messages', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message_text: text })
            });
            const data = await response.json();
            if (data.success && data.message) {
                upsertMessage(data.message);
                renderChatMessages();
            }
        } catch (err) {
            console.error('Gagal mengirim pesan:', err);
        }
    }

    function upsertMessage(message) {
        const index = chatMessagesState.findIndex(item => Number(item.id) === Number(message.id));
        if (index >= 0) {
            chatMessagesState[index] = message;
        } else {
            chatMessagesState.push(message);
        }
        chatMessagesState.sort((a, b) => Number(a.id) - Number(b.id));
    }

    function markConversationRead() {
        if (!activeConversation) return;

        if (chatSocket && chatSocket.connected) {
            chatSocket.emit('chat:read', { thread_id: activeConversation.thread_id });
        } else {
            fetch(`/api/chat/conversations/${activeConversation.thread_id}/read`, { method: 'POST' }).catch(() => {});
        }
    }

    function updateBadge() {
        const badge = document.getElementById('chatBadge');
        if (!badge) return;

        if (unreadCount > 0 && !isChatOpen) {
            badge.innerText = unreadCount > 99 ? '99+' : unreadCount;
            badge.style.display = 'flex';
        } else {
            badge.style.display = 'none';
            badge.innerText = '0';
        }
    }

    function clearBadge() {
        unreadCount = 0;
        updateBadge();
    }

    function scrollToBottom() {
        const container = document.getElementById('chatMessages');
        if (container) container.scrollTop = container.scrollHeight;
    }

    function formatTime(isoString) {
        const d = new Date(isoString);
        return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }).replace(':', '.');
    }

    function escapeHTML(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }
</script>
